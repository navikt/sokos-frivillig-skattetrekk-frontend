{
  "name": "sokos-frivillig-skattetrekk-frontend",
  "version": "1.0.0",
  "description": "Frontend for frivillig skattetrekk for skattepliktige ytelser",
  "type": "module",
  "scripts": {
    "dev": "vite --mode mock",
    "dev:backend": "vite --port 3000",
    "build:development": "tsc && vite build --mode development",
    "build:production": "tsc && vite build --mode production",
    "biome:check": "biome check --files-ignore-unknown=true",
    "biome:fix": "biome check --write --no-errors-on-unmatched",
    "stylelint:check": "stylelint '**/*.css'",
    "stylelint:fix": "stylelint '**/*.css' --fix",
    "prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
  },
  "dependencies": {
    "react-router-dom": "7.14.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@navikt/aksel-icons": "8.10.4",
    "@navikt/aksel-stylelint": "8.10.4",
    "@navikt/ds-css": "8.10.4",
    "@navikt/ds-react": "8.10.4",
    "@navikt/ds-tokens": "8.10.4",
    "@navikt/nav-dekoratoren-moduler": "3.7.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "date-fns": "4.1.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "16.4.0",
    "msw": "2.14.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "stylelint": "17.9.1",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard",
      "@navikt/aksel-stylelint/recommended"
    ],
    "rules": {
      "aksel/design-token-no-global-override": [
        true,
        {
          "severity": "warning"
        }
      ],
      "selector-class-pattern": null
    },
    "ignoreFiles": [
      "dist/**/*",
      "playwright-report/**/*"
    ]
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
    "*.css": "stylelint --fix"
  },
	"engines": {
		"pnpm": ">=11.0.8",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912"
}
