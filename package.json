{
	"name": "sokos-frivillig-skattetrekk-frontend",
	"version": "1.0.0",
	"description": "Frontend for frivillig skattetrekk for skattepliktige ytelser",
	"type": "module",
	"scripts": {
		"dev": "vite --mode mock",
		"dev:backend": "vite --port 3000",
		"build:development": "tsc && vite build --mode development",
		"build:production": "tsc && vite build --mode production",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"react-router-dom": "7.18.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@navikt/aksel-icons": "8.14.0",
		"@navikt/aksel-stylelint": "8.14.0",
		"@navikt/ds-css": "8.14.0",
		"@navikt/ds-react": "8.14.0",
		"@navikt/ds-tokens": "8.14.0",
		"@navikt/nav-dekoratoren-moduler": "4.2.2",
		"@types/node": "26.1.0",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.3",
		"date-fns": "4.4.0",
		"husky": "9.1.7",
		"jsdom": "29.1.1",
		"lint-staged": "17.0.8",
		"msw": "2.14.6",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"stylelint": "17.14.0",
		"stylelint-config-standard": "40.0.0",
		"typescript": "6.0.3",
		"vite": "8.1.3"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"stylelint": {
		"extends": [
			"stylelint-config-standard",
			"@navikt/aksel-stylelint/recommended"
		],
		"rules": {
			"aksel/design-token-no-global-override": [
				true,
				{
					"severity": "warning"
				}
			],
			"selector-class-pattern": null
		},
		"ignoreFiles": [
			"dist/**/*",
			"playwright-report/**/*"
		]
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.7.0",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
